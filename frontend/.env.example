# ── API base ─────────────────────────────────────────────────────────────────
# URL where the backend is running — no trailing slash
NEXT_PUBLIC_API_BASE=http://localhost:8001

# ── Dev bypass ───────────────────────────────────────────────────────────────
# Set true to skip Clerk entirely (backend must also have DEV_MODE=true)
# When true, the app works with no Clerk account — ideal for local dev
NEXT_PUBLIC_DEV_MODE=true

# ── Clerk Auth (required when NEXT_PUBLIC_DEV_MODE=false) ────────────────────
# Get these from clerk.com → Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs — these match Next.js App Router conventions
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in
