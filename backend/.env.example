# ── Database ─────────────────────────────────────────────────────────────────
# Local dev default — adjust user/password/port to match your Postgres setup
DATABASE_URL=postgresql://fitcoach:<your-db-password>@127.0.0.1:5433/fitcoach

# ── Dev bypass ───────────────────────────────────────────────────────────────
# Set true to skip Clerk JWT verification (all requests treated as DEV_USER_ID)
# Must match NEXT_PUBLIC_DEV_MODE in frontend/.env.local
DEV_MODE=true
DEV_USER_ID=dev-user-001

# ── Clerk Auth (required when DEV_MODE=false) ────────────────────────────────
# Get these from clerk.com → Dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-frontend-api>/.well-known/jwks.json

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs that have admin privileges
# In dev mode, include dev-user-001 to access /admin routes
# Get your Clerk user ID from clerk.com → Dashboard → Users → your account
ADMIN_USER_IDS=dev-user-001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins — must match where the frontend is served (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3001
